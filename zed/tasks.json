// Live preview is spawned by the tinymist LSP itself — see
// lsp.tinymist.initialization_options.preview.background in settings.json.
// This task just opens the browser at the LSP preview URL.
[
  {
    "label": "Tinymist: Open Live Preview",
    "command": "open http://127.0.0.1:23635",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "never",
  },
]
