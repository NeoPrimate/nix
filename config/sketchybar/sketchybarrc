#!/usr/bin/env bash
# SketchyBar — aerospace workspaces (left) + system info (right)
# Managed by nix-darwin (services.sketchybar). Config lives in ~/nix/config/sketchybar.

export CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

FONT="Hack Nerd Font"                       # glyph + text icons
APP_FONT="sketchybar-app-font:Regular:16.0" # per-app icon glyphs

##### Bar #####
sketchybar --bar \
  height=37 \
  position=top \
  sticky=on \
  padding_left=8 \
  padding_right=8 \
  color="$BAR_COLOR" \
  corner_radius=0 \
  y_offset=0 \
  margin=0

##### Item defaults #####
sketchybar --default \
  updates=when_shown \
  icon.font="$FONT:Bold:14.0" \
  icon.color="$TEXT" \
  label.font="$FONT:Semibold:13.0" \
  label.color="$TEXT" \
  background.color="$ITEM_BG" \
  background.corner_radius=6 \
  background.height=24 \
  padding_left=3 \
  padding_right=3 \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=6

##### Aerospace workspaces (left) #####
# One item per workspace. The highlight is moved directly by aerospace's
# exec-on-workspace-change (-> plugins/aerospace_focus.sh), bypassing any
# sketchybar event for minimal latency. A hidden observer only handles the
# heavier app-icon recompute on app/window changes.
for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space."$sid" left \
    --set space."$sid" \
      drawing=off \
      icon="$sid" \
      icon.font="$FONT:Bold:14.0" \
      label.font="$APP_FONT" \
      label.y_offset=-1 \
      click_script="aerospace workspace $sid"
done

# Hidden observer (updates=on so it runs while not drawn): full app-icon
# recompute on app/window changes + a slow safety timer. Workspace-switch
# highlighting is handled out-of-band by aerospace_focus.sh (see above).
sketchybar --add item aerospace_icons left \
  --set aerospace_icons drawing=off updates=on update_freq=10 \
    script="$PLUGIN_DIR/aerospace_icons.sh" \
  --subscribe aerospace_icons front_app_switched space_change system_woke

##### System info (right) — added R->L: cpu volume battery date time #####
sketchybar --add item clock right \
  --set clock icon="󰥔" icon.color="$LAVENDER" update_freq=15 \
    script="$PLUGIN_DIR/calendar.sh" \
  \
  --add item cal right \
  --set cal icon="󰃭" icon.color="$BLUE" \
  \
  --add item battery right \
  --set battery icon="󰁹" update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery power_source_change system_woke \
  \
  --add item volume right \
  --set volume icon="󰕾" icon.color="$TEAL" script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change \
  \
  --add item cpu right \
  --set cpu icon="󰻠" icon.color="$GREEN" update_freq=5 script="$PLUGIN_DIR/cpu.sh"

##### Finalize #####
sketchybar --update
"$PLUGIN_DIR/aerospace_icons.sh"   # initial paint + seed the focus cache
