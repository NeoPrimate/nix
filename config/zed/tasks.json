// Zed currently filters tinymist's LSP settings, so the LSP-spawned
// background preview (which would give true on-type updates) cannot be
// configured from settings.json. Workaround: run the standalone preview CLI
// and rely on Zed autosave (200ms) to get near-live updates on file save.
[
  {
    "label": "Tinymist: Web Preview",
    "command": "pkill -f 'tinymist preview' ; sleep 0.3 ; tinymist preview --features html \"$ZED_WORKTREE_ROOT/main.typ\" --root \"$ZED_WORKTREE_ROOT\"",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
  },
]
