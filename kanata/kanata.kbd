(defcfg
  process-unmapped-keys yes
  macos-dev-names-include ("Apple Internal Keyboard / Trackpad")
)

(defsrc
  caps ralt f10 f11 f12
)

(defalias
  hyper (multi lctl lalt lmet)
  meh   (multi lctl lalt lsft)
)

(deflayer base
  (tap-hold 200 200 esc  @hyper)
  (tap-hold 200 200 ralt @meh)
  mute
  vold
  volu
)
